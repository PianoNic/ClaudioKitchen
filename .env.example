# ClaudioKitchen environment configuration
# Copy this file to `.env` and fill in real values. NEVER commit `.env`.
#
#   cp .env.example .env
#
# ---------------------------------------------------------------------------
# OIDC provider (Pocket ID, or any OpenID Connect provider)
# In Pocket ID: create a new OIDC client, set its callback URL to
#   ${BASE_URL}/auth/callback
# ---------------------------------------------------------------------------
OIDC_CONFIG_URL=https://auth.example.com/.well-known/openid-configuration
OIDC_CLIENT_ID=your-oidc-client-id
OIDC_CLIENT_SECRET=your-oidc-client-secret

# Public HTTPS URL of this MCP server (as seen by Claude, behind your reverse
# proxy / tunnel). No trailing slash. Used to build download & callback URLs.
BASE_URL=https://claudio-kitchen.example.com

# Comma-separated allowlist. Only these emails (matched against the OIDC
# provider's userinfo) may call any tool. Case-insensitive.
ALLOWED_EMAILS=you@example.com

# ---------------------------------------------------------------------------
# OpenRouter
# Get a key at https://openrouter.ai/keys  (credits are billed in USD)
# ---------------------------------------------------------------------------
OPENROUTER_API_KEY=sk-or-v1-your-openrouter-key

# ---------------------------------------------------------------------------
# Server
# ---------------------------------------------------------------------------
PORT=8000
FILES_DIR=/data/generated

# Secret that gates the /files/<id> download route (?token=...).
# Set a STABLE random value so download links survive restarts; if left unset,
# a random token is generated per run and printed to the logs.
# Generate one with:  python -c "import secrets; print(secrets.token_urlsafe(24))"
FILES_TOKEN=change-me-to-a-long-random-secret

# ---------------------------------------------------------------------------
# Cost tracking (optional)
# Every generating tool logs its per-request USD cost to an append-only ledger;
# the usage_summary tool reports today / this-month / all-time spend.
# ---------------------------------------------------------------------------
# Path to the cost ledger (defaults to <FILES_DIR>/../usage.jsonl on the volume).
# USAGE_LOG=/data/usage.jsonl

# Optional HARD monthly cap in USD. Once this calendar month's recorded spend
# reaches it, generating tools refuse to run until next month. Unset = no cap.
# MONTHLY_BUDGET_USD=25

# ---------------------------------------------------------------------------
# Optional: override default models (any valid OpenRouter model id).
# Discover ids with the list_models / list_video_models tools.
# ---------------------------------------------------------------------------
# DEFAULT_IMAGE_MODEL=google/gemini-2.5-flash-image
# DEFAULT_TTS_MODEL=openai/gpt-audio
# DEFAULT_STT_MODEL=google/gemini-2.5-flash
